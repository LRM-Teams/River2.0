{
	"name": "@lebronj/pi-playwright",
	"version": "0.0.1",
	"description": "Optional Playwright browser automation package for pi",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx cp README.md dist/"
	},
	"dependencies": {
		"playwright": "1.61.1"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-ai": "*"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"shx": "0.4.0",
		"typescript": "5.9.3"
	},
	"keywords": ["pi-package", "playwright", "browser", "automation"],
	"author": "Jiang HP",
	"license": "MIT",
	"engines": {
		"node": ">=22.19.0"
	},
	"pi": {
		"extensions": ["./dist/index.js"]
	}
}
